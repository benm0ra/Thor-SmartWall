<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ThorSmartWall" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="android:statusBarColor">@color/statusbar</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowBackground">@color/bg_top</item>
    </style>

    <!-- Section eyebrow: small colored category chip + label sit in a row above each tile group -->
    <style name="SectionRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:layout_marginTop">20dp</item>
        <item name="android:layout_marginBottom">10dp</item>
        <item name="android:layout_marginStart">4dp</item>
    </style>

    <style name="SectionLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/ink</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="Tile">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:background">@drawable/tile_bg</item>
        <item name="android:padding">16dp</item>
    </style>

    <style name="TileButton" parent="Widget.AppCompat.Button">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:background">@drawable/tile_button_bg</item>
        <item name="android:textColor">@color/ink</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">15sp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="TileSwitch">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/ink</item>
        <item name="android:textSize">15sp</item>
        <item name="android:layout_marginTop">4dp</item>
        <item name="android:paddingTop">6dp</item>
        <item name="android:paddingBottom">6dp</item>
    </style>

    <style name="TileHint">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/ink_soft</item>
        <item name="android:textSize">12sp</item>
        <item name="android:lineSpacingExtra">1dp</item>
        <item name="android:layout_marginTop">2dp</item>
    </style>

    <style name="TileDivider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:background">@color/tile_border</item>
        <item name="android:layout_marginTop">14dp</item>
        <item name="android:layout_marginBottom">4dp</item>
    </style>

    <style name="TileLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/ink</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="TileRadio">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/ink</item>
        <item name="android:textSize">15sp</item>
        <item name="android:layout_marginTop">2dp</item>
        <item name="android:paddingTop">6dp</item>
        <item name="android:paddingBottom">6dp</item>
        <item name="android:buttonTint">@color/accent</item>
    </style>
</resources>
