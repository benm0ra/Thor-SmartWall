<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111318">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="16dp"
            android:text="@string/tagline"
            android:textColor="#9AA0AC"
            android:textSize="13sp" />

        <!-- Live dual-screen preview, stacked like the closed clamshell -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/previewTop"
                android:layout_width="150dp"
                android:layout_height="266dp"
                android:background="#000000"
                android:scaleType="fitXY"
                android:contentDescription="@string/preview_top_desc" />

            <View
                android:layout_width="150dp"
                android:layout_height="6dp"
                android:background="#2A2E37" />

            <ImageView
                android:id="@+id/previewBottom"
                android:layout_width="150dp"
                android:layout_height="172dp"
                android:background="#000000"
                android:scaleType="fitXY"
                android:contentDescription="@string/preview_bottom_desc" />
        </LinearLayout>

        <Button
            android:id="@+id/btnPickImage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/pick_image" />

        <Button
            android:id="@+id/btnPickVideo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/pick_video" />

        <Button
            android:id="@+id/btnPickGif"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/pick_gif" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchIndependent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/independent_mode" />

        <Button
            android:id="@+id/btnPickSecondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:enabled="false"
            android:text="@string/pick_bottom_image" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchVertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:checked="true"
            android:text="@string/stacked_vertically" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchSwap"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/swap_screen_order" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/hinge_gap"
            android:textColor="#FFFFFF" />

        <SeekBar
            android:id="@+id/seekGap"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <RadioGroup
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/radioKenBurns"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="@string/mode_ken_burns" />

            <RadioButton
                android:id="@+id/radioStatic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/mode_static" />

            <RadioButton
                android:id="@+id/radioVideo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/mode_video" />

            <RadioButton
                android:id="@+id/radioGif"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/mode_gif" />
        </RadioGroup>

        <Button
            android:id="@+id/btnApplyLive"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/apply_live_wallpaper" />

        <Button
            android:id="@+id/btnExport"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/export_split_images" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/export_hint"
            android:textColor="#9AA0AC"
            android:textSize="12sp" />

    </LinearLayout>
</ScrollView>
