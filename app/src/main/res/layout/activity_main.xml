<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0F13"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="18dp">
            <View
                android:layout_width="6dp"
                android:layout_height="26dp"
                android:background="#7C4DFF" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="@string/app_name"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Hero: the Thor silhouette with the live split preview inside it -->
        <FrameLayout
            android:layout_width="170dp"
            android:layout_height="409dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/thor_device_shell">

            <ImageView
                android:id="@+id/previewTop"
                android:layout_width="125dp"
                android:layout_height="222dp"
                android:layout_marginStart="23dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/rounded_screen_bg"
                android:clipToOutline="true"
                android:scaleType="centerCrop"
                android:contentDescription="@string/preview_top_desc" />

            <ImageView
                android:id="@+id/previewBottom"
                android:layout_width="109dp"
                android:layout_height="126dp"
                android:layout_marginStart="30dp"
                android:layout_marginTop="269dp"
                android:background="@drawable/rounded_screen_bg"
                android:clipToOutline="true"
                android:scaleType="centerCrop"
                android:contentDescription="@string/preview_bottom_desc" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="22dp"
            android:text="@string/preview_scale_note"
            android:textColor="#5A6070"
            android:textSize="11sp" />

        <!-- Card: Wallpaper Source -->
        <TextView style="@style/SectionLabel" android:text="@string/section_source" />
        <LinearLayout style="@style/Card">
            <Button style="@style/CardButton" android:id="@+id/btnPickImage" android:text="@string/pick_image" />
            <Button style="@style/CardButton" android:id="@+id/btnPickVideo" android:text="@string/pick_video" />
            <Button style="@style/CardButton" android:id="@+id/btnPickGif" android:text="@string/pick_gif" />
            <Button style="@style/CardButton" android:id="@+id/btnSearchGifs" android:text="@string/search_gifs_online" />
        </LinearLayout>

        <!-- Card: Screen Fit -->
        <TextView style="@style/SectionLabel" android:text="@string/section_fit" />
        <LinearLayout style="@style/Card">
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchIndependent"
                style="@style/CardSwitch"
                android:text="@string/smart_fit_mode"
                android:checked="true" />
            <TextView style="@style/CardHint" android:text="@string/smart_fit_hint" />

            <Button
                style="@style/CardButton"
                android:id="@+id/btnPickSecondary"
                android:layout_marginTop="10dp"
                android:enabled="true"
                android:text="@string/pick_bottom_image" />

            <View style="@style/CardDivider" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchVertical"
                style="@style/CardSwitch"
                android:checked="true"
                android:text="@string/stacked_vertically" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchSwap"
                style="@style/CardSwitch"
                android:text="@string/swap_screen_order" />

            <TextView
                style="@style/CardLabel"
                android:id="@+id/labelHingeGap"
                android:layout_marginTop="10dp"
                android:text="@string/hinge_gap" />
            <SeekBar
                android:id="@+id/seekGap"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Card: Motion -->
        <TextView style="@style/SectionLabel" android:text="@string/section_motion" />
        <LinearLayout style="@style/Card">
            <RadioGroup
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton style="@style/CardRadio" android:id="@+id/radioKenBurns" android:checked="true" android:text="@string/mode_ken_burns" />
                <RadioButton style="@style/CardRadio" android:id="@+id/radioStatic" android:text="@string/mode_static" />
                <RadioButton style="@style/CardRadio" android:id="@+id/radioVideo" android:text="@string/mode_video" />
                <RadioButton style="@style/CardRadio" android:id="@+id/radioGif" android:text="@string/mode_gif" />
            </RadioGroup>
        </LinearLayout>

        <!-- Card: Orientation Fix -->
        <TextView style="@style/SectionLabel" android:text="@string/section_orientation_fix" />
        <LinearLayout style="@style/Card">
            <TextView style="@style/CardHint" android:text="@string/rotation_fix_hint" />
            <TextView
                style="@style/CardLabel"
                android:id="@+id/labelRotationValue"
                android:layout_marginTop="8dp"
                android:textStyle="bold" />
            <Button
                style="@style/CardButton"
                android:id="@+id/btnRotationFix"
                android:text="@string/rotate_90_button" />
        </LinearLayout>

        <!-- Card: Background & Power -->
        <TextView style="@style/SectionLabel" android:text="@string/section_background" />
        <LinearLayout style="@style/Card">
            <TextView style="@style/CardHint" android:text="@string/background_explainer" />
            <Button
                style="@style/CardButton"
                android:id="@+id/btnBatteryOptimization"
                android:layout_marginTop="10dp"
                android:text="@string/keep_running_background" />
        </LinearLayout>

        <!-- Card: Apply -->
        <TextView style="@style/SectionLabel" android:text="@string/section_apply" />
        <LinearLayout style="@style/Card">
            <Button
                android:id="@+id/btnApplyLive"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/accent_button_bg"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:text="@string/apply_live_wallpaper" />

            <Button style="@style/CardButton" android:id="@+id/btnExport" android:layout_marginTop="10dp" android:text="@string/export_split_images" />
            <Button style="@style/CardButton" android:id="@+id/btnDiagnostics" android:text="@string/show_screen_info" />

            <TextView
                style="@style/CardHint"
                android:layout_marginTop="8dp"
                android:text="@string/export_hint" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
