<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111318">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="16dp"
            android:text="@string/tagline"
            android:textColor="#9AA0AC"
            android:textSize="13sp" />

        <!-- Live dual-screen preview, styled like the closed Thor clamshell -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:orientation="vertical"
            android:background="@drawable/device_shell_bg"
            android:padding="10dp">

            <ImageView
                android:id="@+id/previewTop"
                android:layout_width="176dp"
                android:layout_height="313dp"
                android:background="@drawable/rounded_screen_bg"
                android:clipToOutline="true"
                android:scaleType="centerCrop"
                android:contentDescription="@string/preview_top_desc" />

            <!-- Hinge: a slightly recessed bar with two hinge-barrel dots, like the Thor's spine -->
            <FrameLayout
                android:layout_width="176dp"
                android:layout_height="16dp">
                <View
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:layout_gravity="center"
                    android:background="#00000000" />
                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_gravity="center_vertical|start"
                    android:layout_marginStart="14dp"
                    android:background="@drawable/hinge_dot" />
                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_gravity="center_vertical|end"
                    android:layout_marginEnd="14dp"
                    android:background="@drawable/hinge_dot" />
            </FrameLayout>

            <ImageView
                android:id="@+id/previewBottom"
                android:layout_width="176dp"
                android:layout_height="202dp"
                android:background="@drawable/rounded_screen_bg"
                android:clipToOutline="true"
                android:scaleType="centerCrop"
                android:contentDescription="@string/preview_bottom_desc" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="6dp"
            android:text="@string/preview_scale_note"
            android:textColor="#5A6070"
            android:textSize="11sp" />

        <Button
            android:id="@+id/btnPickImage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/pick_image" />

        <Button
            android:id="@+id/btnPickVideo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/pick_video" />

        <Button
            android:id="@+id/btnPickGif"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/pick_gif" />

        <Button
            android:id="@+id/btnSearchGifs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/search_gifs_online" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchIndependent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/independent_mode" />

        <Button
            android:id="@+id/btnPickSecondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:enabled="false"
            android:text="@string/pick_bottom_image" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchVertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:checked="true"
            android:text="@string/stacked_vertically" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchSwap"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/swap_screen_order" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/hinge_gap"
            android:textColor="#FFFFFF" />

        <SeekBar
            android:id="@+id/seekGap"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <RadioGroup
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/radioKenBurns"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="@string/mode_ken_burns" />

            <RadioButton
                android:id="@+id/radioStatic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/mode_static" />

            <RadioButton
                android:id="@+id/radioVideo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/mode_video" />

            <RadioButton
                android:id="@+id/radioGif"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/mode_gif" />
        </RadioGroup>

        <Button
            android:id="@+id/btnApplyLive"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/apply_live_wallpaper" />

        <Button
            android:id="@+id/btnExport"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/export_split_images" />

        <Button
            android:id="@+id/btnDiagnostics"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/show_screen_info" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/export_hint"
            android:textColor="#9AA0AC"
            android:textSize="12sp" />

    </LinearLayout>
</ScrollView>
