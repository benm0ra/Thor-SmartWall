<?xml version="1.0" encoding="utf-8"?>
<!--
  Landscape Switch-style Thor: wide top screen, hinge, wider-but-shorter bottom screen flanked
  by left stick+D-pad and right stick+Y-X-A-B diamond. Confirmed against a reference photo of the
  running device. Tuned to read as a physical device sitting on the light 3DS-style background.
  The live-preview ImageViews sit on the transparent screen cutouts - see activity_main.xml.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
